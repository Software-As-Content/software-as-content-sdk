# SaC SDK — Environment Variables
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# Required — OpenRouter API key (get one at https://openrouter.ai/keys)
# This is used to call LLMs (Gemini, Claude, GPT, etc.) via OpenRouter
SAC_API_KEY=sk-or-v1-your-key-here

# Optional — Tavily API key for web search (get one at https://app.tavily.com/)
# Enables real-time data in generated UIs (news, stock prices, weather, etc.)
# Without this key, generation still works but won't include live data
SAC_SEARCH_API_KEY=tvly-your-key-here
