# SaC SDK — Environment Variables
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# Required — API key for sac interaction layer app generation LLM
# Supports OpenRouter, Anthropic, or any OpenAI-compatible provider
# Anthropic keys (sk-ant-*) are auto-detected; all others default to OpenRouter
SAC_API_KEY=sk-or-v1-your-key-here

# Optional — Custom API endpoint (for OpenAI direct, ollama, vLLM, etc.)
# Leave unset to use OpenRouter (default)
# SAC_API_BASE=https://api.openai.com/v1/chat/completions

# Optional — Override the default generation model
# SAC_MODEL=google/gemini-3-flash-preview

# Optional — Tavily API key for web search (https://app.tavily.com/)
# Enables real-time data in generated apps (news, prices, weather, etc.)
# SAC_SEARCH_API_KEY=tvly-your-key-here

# Optional — Where to persist conversations (default: .sac)
# SAC_DATA_DIR=~/.sac
